{
  "name": "node-red-contrib-timer-events",
  "version": "0.1.4",
  "description": "An enhanced Node-RED timer node with variable delay, pause/resume, persistent state, cooldown and configurable reporting.",
  "repository": {
    "type": "git",
    "url": "https://github.com/mchristegh/node-red-contrib-timer-events/"
  },
  "license": "Apache-2.0",
  "keywords": [
    "node-red",
    "timer",
    "delay",
    "stoptimer",
    "cooldown",
    "pause",
    "resume",
    "persist"
  ],
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "test": "node test-scripts/test-harness.js",
    "prepublishOnly": "node test-scripts/test-harness.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "node-red": {
    "version": ">=2.0.0",
    "nodes": {
      "timer-events": "timer-events/test-harness.js"
    }
  },
  "author": {
    "name": "mchristegh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.7.0",
    "prettier": "^3.9.5"
  }
}
